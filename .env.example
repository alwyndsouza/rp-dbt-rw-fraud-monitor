# Runtime rates
FRAUD_RATE=0.10
TRANSACTION_RATE=20
LOGIN_RATE=5
CARD_RATE=1
ALERT_RATE=8
KYC_RATE=0.5
CUSTOMER_POOL_SIZE=500
STRUCTURING_THRESHOLD=10000

# Producer reliability controls
MINUTE_TICK_ENABLED=true
MINUTE_TICK_TRANSACTIONS=30
MINUTE_TICK_LOGINS=10
ALERT_WORKERS=4
ALERT_QUEUE_SIZE=2000

# Broker connectivity
REDPANDA_BROKERS=redpanda:29092
REDPANDA_SECURITY_PROTOCOL=PLAINTEXT
REDPANDA_SASL_MECHANISM=
REDPANDA_SASL_USERNAME=
REDPANDA_SASL_PASSWORD=

# Grafana admin (rotate in any shared or prod environment)
GRAFANA_ADMIN_USER=fraud_admin
GRAFANA_ADMIN_PASSWORD=change_me_now
