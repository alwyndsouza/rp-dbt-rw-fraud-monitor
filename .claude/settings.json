{
  "permissions": {
    "allow": [
      "Bash(python -m pytest*)",
      "Bash(python -c*)",
      "Bash(ruff check*)",
      "Bash(ruff format*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(docker compose config*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(psql*)",
      "Bash(ls*)",
      "Bash(find producers/ -name '*.py'*)",
      "Bash(find sql/ -name '*.sql'*)",
      "Bash(cat*)",
      "Bash(echo*)",
      "Bash(wc*)",
      "Bash(grep*)",
      "Bash(sqlfluff lint*)",
      "Bash(sqlfluff fix*)",
      "Bash(pre-commit run*)",
      "Bash(uv pip install*)",
      "Bash(uv sync*)",
      "Bash(pip install*)"
    ],
    "deny": [
      "Bash(docker compose down -v*)",
      "Bash(make reset*)",
      "Bash(rm -rf*)",
      "Bash(DROP TABLE*)",
      "Bash(DROP SOURCE*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/fraud-detection-streaming && bash .claude/hooks/post-edit.sh \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/fraud-detection-streaming/.claude/hooks/pre-bash.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      }
    ]
  }
}
