[sqlfluff]
dialect = postgres
templater = dbt

[sqlfluff:templater:dbt]
project_dir = fraud_detection/
profiles_dir = fraud_detection/
profile = fraud_detection
target = dev

# RisingWave DDL isn't fully supported by sqlfluff parsing.
# Keep style linting, but don't fail CI on parser gaps.
ignore = parsing
exclude_rules = LT05,LT01,LT12,ST05,RF05,AL05
